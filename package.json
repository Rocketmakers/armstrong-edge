{
  "name": "@rocketmakers/armstrong-root",
  "version": "3.0.1",
  "description": "Rocketmakers React component library",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rocketmakers/armstrong-edge.git"
  },
  "author": "developers@rocketmakers.com",
  "license": "MIT",
  "scripts": {
    "setup": "asdf install && pnpm install && (cd module && pnpm install) && (cd storybook && pnpm install)",
