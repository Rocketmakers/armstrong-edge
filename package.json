    "storybook": "(cd storybook && pnpm storybook)",
    "test-storybook": "(cd storybook && pnpm test-storybook)"
  },
  "devDependencies": {
    "commitizen": "4.3.0",
    "husky": "8.0.3",
    "watch": "1.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./scripts/cz-ai"
    }
  }
}
