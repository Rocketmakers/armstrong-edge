{
  "name": "@rocketmakers/armstrong",
  "version": "5.0.0",
  "description": "Rocketmakers React component library",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rocketmakers/armstrong-edge.git"
  },
  "scripts": {
    "start": "concurrently -n armstrong- pnpm:watch-*",
    "copy-readme": "cp ../README.md ./README.md",
    "build": "pnpm copy-readme && tsc && vite build --mode production",
    "watch-ts": "vite build --watch",
    "test": "jest",
    "test-ci": "jest --ci",
    "format": "prettier --check \"**/*.{ts,tsx,md,css,js,mjs,json}\"",
    "format-fix": "prettier --write \"**/*.{ts,tsx,md,css,js,mjs,json}\"",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "stylelint": "stylelint 'src/**/*.{css,scss}' --fix"
  },
  "peerDependencies": {
    "date-fns": "2.x",
    "react": "19.x",
    "react-dom": "19.x",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "manager.ts"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs",
      "types": "./dist/*/index.d.ts"
    },
    "./css": "./dist/style.css"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*/index.d.ts",
        "./dist/index.d.ts"
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@rocketmakers/shell-commands": "7.1.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@storybook/addon-docs": "^8.4.7",
    "@storybook/react": "8.4.7",
    "@storybook/test": "8.4.7",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/glob": "8.1.0",
    "@types/jest": "29.5.3",
    "@types/lodash": "4.14.195",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "chokidar": "3.5.3",
    "concurrently": "8.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "http-server": "14.1.1",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.6.1",
    "jest-config": "29.6.1",
    "jest-environment-jsdom": "29.6.1",
    "jest-junit": "16.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sass": "1.63.6",
    "scss-concat": "0.3.9",
    "semantic-release": "25.0.3",
    "storybook": "8.4.7",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "4.4.4",
    "vite-plugin-dts": "3.2.0",
    "vite-plugin-sdk": "0.1.2",
    "vite-plugin-static-copy": "0.16.0",
    "vite-plugin-turbosnap": "1.0.3",
    "wait-on": "7.0.1",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "react-datepicker": "8.0.0",
    "react-icons": "4.10.1",
    "react-select": "5.10.0"
  }
}
